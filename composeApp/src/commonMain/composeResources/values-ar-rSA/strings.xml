    <string name="meal_q_essentials_title">Meal Planning Essentials</string>
    <string name="meal_q_essentials_desc">These answers define what the AI can safely suggest for recipes, portions and weekly prep.</string>
    <string name="meal_q_cooking_for_title">How many people are we cooking for?</string>
    <string name="meal_q_cooking_for_desc">Scales ingredient quantities and portion sizes.</string>
    <string name="meal_q_dietary_title">Are there any dietary restrictions or allergies?</string>
    <string name="meal_q_dietary_desc">Acts as a hard filter for restricted foods and allergens.</string>
    <string name="meal_q_disliked_title">Are there any ingredients you absolutely hate?</string>
    <string name="meal_q_disliked_desc">Keeps meal plans away from foods the household dislikes.</string>
    <string name="meal_q_disliked_placeholder">Example: cilantro, mushrooms, olives</string>
    <string name="meal_q_lifestyle_title">Lifestyle &amp;amp; Time Constraints</string>
    <string name="meal_q_lifestyle_desc">These answers keep plans realistic for busy days and match the cooking effort you want.</string>
    <string name="meal_q_weeknight_time_title">On a busy weeknight, how much time do you realistically have to cook?</string>
    <string name="meal_q_weeknight_time_desc">Filters recipes by prep and cook time.</string>
    <string name="meal_q_skill_title">What is your cooking style/skill level?</string>
    <string name="meal_q_skill_desc">Keeps meal suggestions aligned with your preferred complexity.</string>
    <string name="meal_q_lunch_title">How do you prefer to handle lunches?</string>
    <string name="meal_q_lunch_desc">Lets the AI decide whether to scale dinners for leftovers.</string>
    <string name="meal_q_friction_title">Right Now Friction Solver</string>
    <string name="meal_q_friction_desc">Use this when you open the app in a panic and need the AI to pick the right behavior mode immediately.</string>
    <string name="meal_q_goal_today_title">What's your goal today?</string>
    <string name="meal_q_goal_today_desc">Sets the AI mode: batch planning, inventory clearance, or grocery logistics.</string>
    <string name="meal_q_local_context_title">Local Shopping Context</string>
    <string name="meal_q_local_context_desc">Allow GPS geolocation or provide your location manually so meal plans and grocery lists can be tailored with nearby shops, seasonal local products, and realistic availability.</string>
    <string name="meal_q_localize_grocery_title">How should we localize grocery suggestions?</string>
    <string name="meal_q_localize_grocery_desc">This helps tailor grocery lists to local shops and products.</string>
    <string name="meal_q_manual_location_title">Where should we plan around?</string>
    <string name="meal_q_manual_location_desc">Add a city, neighborhood, postal code, or market area.</string>
    <string name="meal_q_manual_location_placeholder">Example: Portici, Naples or 80055</string>
