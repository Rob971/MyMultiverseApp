# Copy to keystore.properties (gitignored) for local release / Play Store builds.
# Generate a keystore once (store offline backup + passwords in a password manager):
#
#   keytool -genkeypair -v \
#     -keystore ammo-upload.jks \
#     -alias ammo-upload \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Paths are relative to the repository root.

storeFile=ammo-upload.jks
storePassword=your_store_password
keyAlias=ammo-upload
keyPassword=your_key_password
