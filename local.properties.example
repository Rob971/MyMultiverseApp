# Copy to local.properties (gitignored) and fill in your Supabase publishable/anon key.
# Dashboard: Project Settings → API → Project URL + anon / publishable key
#
# supabase.url is optional; defaults to the production project URL in composeApp/build.gradle.kts.
supabase.url=https://ammo.mymultiverse.app
supabase.anonKey=your_supabase_anon_or_publishable_key_here

# Optional: Gemini API key for AI-powered dish ingredient generation.
# Get a free key at https://aistudio.google.com/app/apikey
# When omitted, the app falls back to local heuristic ingredient suggestions.
gemini.apiKey=your_gemini_api_key_here

# Optional: Play Store / release signing (alternative to keystore.properties at repo root).
# ammo.upload.storeFile=ammo-upload.jks
# ammo.upload.storePassword=your_store_password
# ammo.upload.keyAlias=ammo-upload
# ammo.upload.keyPassword=your_key_password
